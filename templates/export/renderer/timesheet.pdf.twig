{% extends 'export/pdf-layout.html.twig' %}
{% set showRateColumn = false %}
{% set showRateBudget = false %}
{% set showTimeBudget = false %}
{% set showUserColumn = true %}
{% set showCustomerSummary = false %}
{% set decimal = true %}
{% set showPageBreak = entries|length > 10 %}
{% block title %}{{ 'timesheet'|trans }}{% endblock %}

{% block items %}
    {% block items_header %}
        <h3>{{ 'export.full_list'|trans }}</h3>
    {% endblock %}

    {% set duration = 0 %}
    {% set detailColumns = showUserColumn ? 9 : 8 %}
    <table class="items">
        <thead>
        <tr>
            <th>{{ 'date'|trans }}</th>
            <th>{{ 'start'|trans }}</th>
            <th>{{ 'end'|trans }}</th>
            <th class="center">{{ 'duration'|trans }}</th>
            <th>{{ 'customer'|trans }}</th>
            <th>{{ 'project'|trans }}</th>
            <th>{{ 'activity'|trans }}</th>
            {% if showUserColumn %}
                <th>{{ 'user'|trans }}</th>
            {% endif %}
            <th>{{ 'description'|trans }}</th>
        </tr>
        </thead>
        <tbody>
        {% for entry in entries %}
            <!-- CONTENT_PART -->
            {% set duration = duration + entry.duration %}
            <tr class="{{ cycle(['odd', 'even'], loop.index0) }}">
                <td class="text-nowrap">{{ entry.begin|date_short }}</td>
                <td class="text-nowrap">{{ entry.begin|time }}</td>
                <td class="text-nowrap">{% if entry.end %}{{ entry.end|time }}{% else %}-{% endif %}</td>
                <td class="duration">{{ entry.duration|duration(decimal) }}</td>
                <td>{{ entry.project.customer.name }}</td>
                <td>{{ entry.project.name }}</td>
                <td>{% if entry.activity %}{{ entry.activity.name }}{% endif %}</td>
                {% if showUserColumn %}
                    <td>{{ entry.user.displayName }}</td>
                {% endif %}
                <td>{% if entry.description is not empty %}{{ entry.description|desc2html }}{% endif %}</td>
            </tr>
        {% endfor %}
        <tr class="summary">
            <td colspan="3">{{ 'sum.total'|trans }}</td>
            <td class="totals duration">{{ duration|duration(decimal) }}</td>
            <td colspan="{{ detailColumns - 4 }}"></td>
        </tr>
        </tbody>
    </table>
{% endblock %}
