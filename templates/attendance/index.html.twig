{% extends 'page_setup.html.twig' %}

{% block page_class %}attendance-page{% endblock %}

{% block main %}
    {% embed '@theme/embeds/card.html.twig' with {fullsize: true} %}
        {% block box_title %}{{ 'attendance.title'|trans }}{% endblock %}
        {% block box_body_class %}p-0{% endblock %}
        {% block box_body %}
            <div class="card-body border-bottom">
                <p class="text-muted mb-0">{{ 'attendance.help'|trans }}</p>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter">
                    <thead>
                        <tr>
                            <th>{{ 'date'|trans }}</th>
                            <th>{{ 'attendance.clock_in'|trans }}</th>
                            <th>{{ 'attendance.clock_out'|trans }}</th>
                            <th>{{ 'attendance.shift'|trans }}</th>
                            <th>{{ 'attendance.source'|trans }}</th>
                            <th>{{ 'attendance.synced_at'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for record in records %}
                            <tr>
                                <td>{{ record.date|date_short }}</td>
                                <td>{{ record.clockIn ? record.clockIn|date_time : '—' }}</td>
                                <td>{{ record.clockOut ? record.clockOut|date_time : '—' }}</td>
                                <td>
                                    {% if record.resolvedShiftId %}
                                        {% set shiftId = record.resolvedShiftId|lower %}
                                        <div class="attendance-shift attendance-shift--{{ shiftId }}">
                                            <span class="attendance-shift__badge">{{ ('shift.name_' ~ shiftId)|trans }}</span>
                                            <span class="attendance-shift__time">{{ ('shift.hours_' ~ shiftId)|trans }}</span>
                                        </div>
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>{{ record.externalSource ?? '—' }}</td>
                                <td>{{ record.syncedAt ? record.syncedAt|date_time : '—' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">{{ 'attendance.empty'|trans }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
    {% endembed %}
{% endblock %}
