{% extends 'page_setup.html.twig' %}

{% block page_class %}quick-entry-page{% endblock %}

{% block main %}
    {{ form_start(form, {attr: {id: 'quick-entries-form', class: 'form-dataTable quick-entries', 'data-locked': locked ? '1' : '0', 'data-label-actions': 'actions'|trans, 'data-label-delete': 'action.delete'|trans, 'data-max-hours': max_hours_per_day}}) }}
    {% embed '@theme/embeds/card.html.twig' with {use_footer: not locked} %}
        {% import "macros/widgets.html.twig" as widgets %}
        {% block box_attributes %}id="quick_entry_box"{% endblock %}
        {% block box_class %}mt-2{% endblock %}
        {% block box_tools %}
            {% if not locked %}
            <div class="qe-shift-selector" role="group" aria-label="{{ 'shift.label'|trans }}">
                {% set shiftQuery = app.request.query.all|merge({'shift': 'A'}) %}
                <a href="{{ path('quick_entry', shiftQuery) }}" class="qe-shift-btn qe-shift-btn--a{% if default_shift == 'A' %} is-active{% endif %}">
                    <span class="qe-shift-btn__label">{{ 'shift.name_a'|trans }}</span>
                    <span class="qe-shift-btn__time">{{ 'shift.hours_a'|trans }}</span>
                </a>
                {% set shiftQuery = app.request.query.all|merge({'shift': 'B'}) %}
                <a href="{{ path('quick_entry', shiftQuery) }}" class="qe-shift-btn qe-shift-btn--b{% if default_shift == 'B' %} is-active{% endif %}">
                    <span class="qe-shift-btn__label">{{ 'shift.name_b'|trans }}</span>
                    <span class="qe-shift-btn__time">{{ 'shift.hours_b'|trans }}</span>
                </a>
            </div>
            {% endif %}
        {% endblock %}
        {% block box_footer %}
            <div class="qe-footer-actions">
                <input type="submit" value="{{ 'action.save'|trans }}" class="btn btn-primary" />
                <button type="button" class="btn btn-outline-primary add-item-link" data-collection-prototype="{{ form.rows.vars.id }}" data-collection-holder="ts-collection">
                    {{ icon('create', true) }}
                    {{ 'action.add'|trans }}
                </button>
            </div>
        {% endblock %}
        {# "table-responsive" does not work, because that would render dropdowns at the bottom behind the container #}
        {% block box_body_class %}p-0{% endblock %}
        {% block box_body %}
            {% if locked %}
                {{ widgets.alert('warning', 'The chosen date is already locked.'|trans({}, 'validators')) }}
            {% endif %}
            {{ form_errors(form) }}
            <div class="qe-table-scroll">
            <table class="table dataTable qe-week-table">
                <thead class="sticky-top">
                    <tr>
                        <th>{{ 'project'|trans }}</th>
                        <th>{{ 'activity'|trans }}</th>
                        {% for field in metaColumns|sort((a, b) => a.order <=> b.order) %}
                            <th style="min-width: 70px">{{ field.label }}</th>
                        {% endfor %}
                        {% for id, week in days %}
                        <th class="text-center{% if week.day is weekend %} weekend{% endif %}{% if week.day is today %} today{% endif %}">
                            {{ week.day|date_weekday }}
                        </th>
                        {% endfor %}
                        <th class="summary">{{ 'duration'|trans }}</th>
                        <th class="text-center qe-actions-header">{{ 'actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody id="ts-collection" data-index="{{ form.rows.children|length }}">
                    {{ form_widget(form.rows) }}
                </tbody>
                <tfoot>
                    <tr class="summary">
                        <td>{{ 'stats.durationTotal'|trans }}</td>
                        <td></td>
                        {% for field in metaColumns %}
                            <td></td>
                        {% endfor %}
                        {% for id, week in days %}
                            <td class="text-center total qe-day-total" id="qe-totals-day-{{ loop.index0 }}" data-max-seconds="{{ max_hours_per_day * 3600 }}"></td>
                        {% endfor %}
                        <td class="text-center total" id="qe-totals-week"></td>
                        <td class="qe-actions-footer"></td>
                    </tr>
                </tfoot>
            </table>
            </div>
        {% endblock %}
    {% endembed %}
    {{ form_end(form) }}
{% endblock %}
